@page "/Error"
@layout shmantry.Shared.Layout.EmptyLayout

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:1rem;font-family:Roboto,sans-serif;">
    <span style="font-size:3rem;">⚠️</span>
    <h2 style="color:#fd8122;">Ein Fehler ist aufgetreten</h2>
    <p style="color:#888;">Bitte lade die Seite neu.</p>
    <button onclick="location.reload()" style="padding:.5rem 1.5rem;background:#fd8122;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:1rem;">
        Neu laden
    </button>
</div>
