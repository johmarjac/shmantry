@page "/"
@inject NavigationManager Navigation

<PageTitle>Shmantry</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:700;">Dashboard</MudText>

<AuthorizeView>
    <Authorized>
        <MudPaper Class="pa-4 mb-3" Elevation="0" Style="border-radius:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1">@context.User.Identity?.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">OneDrive verbunden</MudText>
                </MudStack>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => Navigation.NavigateTo($"{Navigation.BaseUri}authentication/logout"))">
                    Abmelden
                </MudButton>
            </MudStack>
        </MudPaper>
    </Authorized>
    <NotAuthorized>
        <MudPaper Class="pa-4 mb-3" Elevation="0" Style="border-radius:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1">OneDrive</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nicht verbunden</MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => Navigation.NavigateTo($"{Navigation.BaseUri}authentication/login"))">
                    Anmelden
                </MudButton>
            </MudStack>
        </MudPaper>
    </NotAuthorized>
</AuthorizeView>

<MudGrid>
    <MudItem xs="6">
        <MudPaper Class="pa-4" Elevation="0" Style="border-radius:16px;text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-1">0</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Artikel</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6">
        <MudPaper Class="pa-4" Elevation="0" Style="border-radius:16px;text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-1">0</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Läuft bald ab</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
