@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="position:relative;border-radius:12px;overflow:hidden;background:#000;">
    <video @ref="_videoRef" autoplay playsinline muted
           style="width:100%;display:block;max-height:60vh;object-fit:cover;" />
    <canvas @ref="_canvasRef" style="display:none;" />

    @* Viewfinder overlay *@
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
        <div style="width:60%;aspect-ratio:1;border:2px solid #594ae2;border-radius:8px;box-shadow:0 0 0 9999px rgba(0,0,0,.4);" />
    </div>

    @if (_error != null)
    {
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
            <MudAlert Severity="Severity.Error" Style="margin:16px;">@_error</MudAlert>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<string> OnDetected { get; set; }

    private ElementReference _videoRef;
    private ElementReference _canvasRef;
    private IJSObjectReference? _module;
    private CancellationTokenSource _cts = new();
    private string? _error;

    private const int CaptureW = 640;
    private const int CaptureH = 480;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/Shmantry.Shared/barcode-scanner.js");

        var ok = await _module.InvokeAsync<bool>("startCamera", _videoRef);
        if (!ok)
        {
            _error = "Kein Kamerazugriff möglich.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _ = ScanLoopAsync(_cts.Token);
    }

    private async Task ScanLoopAsync(CancellationToken ct)
    {
        var reader = new ZXing.BarcodeReaderGeneric
        {
            Options = new ZXing.Common.DecodingOptions
            {
                TryHarder = true,
                PossibleFormats =
                [
                    ZXing.BarcodeFormat.QR_CODE,
                    ZXing.BarcodeFormat.EAN_13,
                    ZXing.BarcodeFormat.EAN_8,
                    ZXing.BarcodeFormat.CODE_128,
                    ZXing.BarcodeFormat.CODE_39,
                    ZXing.BarcodeFormat.UPC_A,
                    ZXing.BarcodeFormat.UPC_E,
                    ZXing.BarcodeFormat.DATA_MATRIX,
                    ZXing.BarcodeFormat.PDF_417,
                    ZXing.BarcodeFormat.AZTEC,
                ]
            }
        };

        while (!ct.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(150, ct);

                var pixels = await _module!.InvokeAsync<byte[]>("captureFrame", ct, _videoRef, _canvasRef);
                if (pixels is not { Length: > 0 }) continue;

                var source = new ZXing.RGBLuminanceSource(
                    pixels, CaptureW, CaptureH,
                    ZXing.RGBLuminanceSource.BitmapFormat.RGBA32);

                var result = reader.Decode(source);
                if (result is not null)
                {
                    await InvokeAsync(() => OnDetected.InvokeAsync(result.Text));
                    return;
                }
            }
            catch (OperationCanceledException) { break; }
            catch { /* frame errors are non-fatal */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stopCamera"); } catch { }
            await _module.DisposeAsync();
        }
        _cts.Dispose();
    }
}
