@using shmantry.Shared.Services
@inject NavigationManager Navigation
@inject IShmantryService ShmantryService

<MudThemeProvider IsDarkMode="true" Theme="@_theme" />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudPopoverProvider />

<Router AppAssembly="typeof(Layout.MainLayout).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private MudTheme? _theme;

    protected override void OnInitialized()
    {
        _theme = new MudTheme();
        // ── Backgrounds ──────────────────────────────────────────
        _theme.PaletteDark.Background        = MudColor.Parse("111111");
        _theme.PaletteDark.Surface           = MudColor.Parse("1c1c1e");
        _theme.PaletteDark.DrawerBackground  = MudColor.Parse("181818");
        _theme.PaletteDark.AppbarBackground  = MudColor.Parse("181818");
        // ── Accent ───────────────────────────────────────────────
        _theme.PaletteDark.Primary              = MudColor.Parse("fd8122");
        _theme.PaletteDark.PrimaryContrastText  = MudColor.Parse("111111");
        // ── Secondary: was #444 (invisible) → readable grey ──────
        _theme.PaletteDark.Secondary            = MudColor.Parse("9e9e9e");
        _theme.PaletteDark.SecondaryContrastText = MudColor.Parse("111111");
        // ── Text / icons ─────────────────────────────────────────
        _theme.PaletteDark.TextPrimary   = MudColor.Parse("f0f0f0");
        _theme.PaletteDark.TextSecondary = MudColor.Parse("9e9e9e");
        _theme.PaletteDark.TextDisabled  = MudColor.Parse("4a4a4a");
        _theme.PaletteDark.ActionDefault = MudColor.Parse("9e9e9e");
        // ── Lines / dividers ─────────────────────────────────────
        _theme.PaletteDark.LinesDefault = MudColor.Parse("2a2a2a");
        _theme.PaletteDark.LinesInputs  = MudColor.Parse("3a3a3a");
        _theme.PaletteDark.Divider      = MudColor.Parse("2a2a2a");

        if (ShmantryService.IsAppInitialized())
            Navigation.NavigateTo("home");
        else
            Navigation.NavigateTo("setup");
    }
}
