@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IShmantryService ShmantryService
@inject ISnackbar Snackbar
@inject IFormFactor FormFactor
@inject IJSRuntime JS
@inject IDialogService DialogService
@implements IDisposable

<style>
    .shm-nav-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        padding: 6px 0;
        cursor: pointer;
        user-select: none;
        background: none;
        border: none;
        width: 100%;
        -webkit-tap-highlight-color: transparent;
    }
    .shm-nav-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }
</style>

<MudLayout>
    <MudMainContent Class="pb-16">
        @Body
    </MudMainContent>
    <MudAppBar Bottom="true" Fixed="true" Color="Color.Dark" Elevation="8" Dense="true">
        <MudGrid Justify="Justify.Center" Spacing="0" Class="w-100">
            <MudItem xs="4" Class="d-flex justify-center">
                <button class="shm-nav-btn" @onclick="@(() => Navigation.NavigateTo("home"))">
                    <MudIcon Icon="@Icons.Material.Filled.Home" Color="@NavColor("/home")" />
                    <span class="shm-nav-label" style="color:@NavColorHex("/home");">Dashboard</span>
                </button>
            </MudItem>
            <MudItem xs="4" Class="d-flex justify-center">
                <button class="shm-nav-btn" @onclick="@(() => Navigation.NavigateTo("inventory"))">
                    <MudIcon Icon="@Icons.Material.Filled.Kitchen" Color="@NavColor("/inventory")" />
                    <span class="shm-nav-label" style="color:@NavColorHex("/inventory");">Vorräte</span>
                </button>
            </MudItem>
            <MudItem xs="4" Class="d-flex justify-center">
                <button class="shm-nav-btn" @onclick="@(() => Navigation.NavigateTo("settings"))">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="@NavColor("/settings")" />
                    <span class="shm-nav-label" style="color:@NavColorHex("/settings");">Einstellungen</span>
                </button>
            </MudItem>
        </MudGrid>
    </MudAppBar>
</MudLayout>

@code {
    protected override void OnInitialized()
    {
        ShmantryService.OnAutoSaved += HandleAutoSaved;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (FormFactor.GetFormFactor() != "Web") return;
        if (!ShmantryService.IsAppInitialized()) return;
        await CheckOneDriveConflictAsync();
    }

    private void HandleAutoSaved(AutoSaveStatus status)
    {
        var (msg, sev) = status switch
        {
            AutoSaveStatus.LocalAndOneDrive => ("Gespeichert (lokal + OneDrive)", Severity.Success),
            AutoSaveStatus.OneDriveFailed   => ("Lokal gespeichert – OneDrive-Sync fehlgeschlagen", Severity.Warning),
            _                               => ("Lokal gespeichert", Severity.Success)
        };
        Snackbar.Add(msg, sev, cfg =>
        {
            cfg.VisibleStateDuration = 2000;
            cfg.ShowTransitionDuration = 200;
            cfg.HideTransitionDuration = 200;
        });
        InvokeAsync(StateHasChanged);
    }

    private async Task CheckOneDriveConflictAsync()
    {
        try
        {
            var isSignedIn = await JS.InvokeAsync<bool>("shmantry.oneDrive.isSignedIn");
            if (!isSignedIn) return;

            var json = await JS.InvokeAsync<string?>("shmantry.oneDrive.loadFile");
            if (string.IsNullOrEmpty(json)) return;

            var odData = System.Text.Json.JsonSerializer.Deserialize<ExportData>(json);
            if (odData?.ExportedAt == null || !ShmantryService.LastExportedAt.HasValue) return;

            var diffSec = Math.Abs((odData.ExportedAt.Value - ShmantryService.LastExportedAt.Value).TotalSeconds);
            if (diffSec < 10) return;

            await ResolveConflictAsync(json, ShmantryService.LastExportedAt, odData.ExportedAt);
        }
        catch { }
    }

    private async Task ResolveConflictAsync(string oneDriveJson, DateTime? localAt, DateTime? odAt)
    {
        var p = new DialogParameters<ConflictDialog>
        {
            { x => x.LocalTimestamp,    localAt },
            { x => x.OneDriveTimestamp, odAt }
        };
        var d = await DialogService.ShowAsync<ConflictDialog>("Sync-Konflikt", p);
        var result = await d.Result;
        if (result.Canceled) return;

        if (result.Data is not ConflictDialog.ConflictChoice choice) return;
        switch (choice)
        {
            case ConflictDialog.ConflictChoice.LoadOneDrive:
                await ShmantryService.ImportDataAsync(oneDriveJson);
                Snackbar.Add("Von OneDrive geladen.", Severity.Success);
                Navigation.NavigateTo("home", forceLoad: false);
                break;
            case ConflictDialog.ConflictChoice.Merge:
                await ShmantryService.MergeDataAsync(oneDriveJson);
                Snackbar.Add("Stände zusammengeführt.", Severity.Success);
                Navigation.NavigateTo("home", forceLoad: false);
                break;
        }
    }

    public void Dispose()
    {
        ShmantryService.OnAutoSaved -= HandleAutoSaved;
    }

    private Color NavColor(string path) =>
        Navigation.Uri.Contains(path) ? Color.Primary : Color.Default;

    private string NavColorHex(string path) =>
        Navigation.Uri.Contains(path) ? "#fd8122" : "#6e6e73";
}
