@inject IShmantryService ShmantryService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Class="mr-2" />
            @FoodItemName
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_locationGroups.Count > 0)
        {
            <MudSelect @bind-Value="_locationId" Label="Lagerort" Variant="Variant.Outlined"
                       FullWidth="true" Class="mb-3" Required="true">
                @foreach (var group in _locationGroups)
                {
                    <MudSelectItem Disabled="true" Value="@("__" + group.HomeName)">
                        <MudText Typo="Typo.overline">@group.HomeName</MudText>
                    </MudSelectItem>
                    @foreach (var loc in group.Locations)
                    {
                        <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                }
            </MudSelect>
        }
        <MudNumericField @bind-Value="_quantity" Label="Anzahl" Variant="Variant.Outlined"
                         Min="1" FullWidth="true" Class="mb-3" />
        <MudDatePicker @bind-Date="_bestBefore" Label="Mindesthaltbarkeitsdatum (optional)"
                       Variant="Variant.Outlined" Clearable="true" DateFormat="dd.MM.yyyy" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="@(!CanSave)">
            Hinzufügen
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string FoodItemId { get; set; } = string.Empty;
    [Parameter] public string FoodItemName { get; set; } = string.Empty;
    [Parameter] public string? StorageLocationId { get; set; }

    private string _locationId = string.Empty;
    private int _quantity = 1;
    private DateTime? _bestBefore;

    private record LocationGroup(string HomeName, List<StorageLocation> Locations);
    private List<LocationGroup> _locationGroups = [];

    protected override async Task OnInitializedAsync()
    {
        if (StorageLocationId != null)
        {
            _locationId = StorageLocationId;
            return;
        }
        var homes = await ShmantryService.GetHomesAsync();
        foreach (var home in homes)
        {
            var locs = await ShmantryService.GetStorageLocationsAsync(home.Id);
            if (locs.Count > 0)
                _locationGroups.Add(new LocationGroup(home.Name, locs));
        }
        if (_locationGroups.Count > 0)
            _locationId = _locationGroups[0].Locations[0].Id;
    }

    private bool CanSave =>
        _quantity >= 1
        && !string.IsNullOrEmpty(_locationId)
        && !_locationId.StartsWith("__");

    private async Task Save()
    {
        await ShmantryService.AddItemEntryAsync(_locationId, FoodItemId, _quantity, _bestBefore);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
