@inject IShmantryService ShmantryService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-2" />
            @(Location != null ? "Lagerort bearbeiten" : "Lagerort hinzufügen")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined"
                      FullWidth="true" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="Beschreibung (optional)"
                      Variant="Variant.Outlined" FullWidth="true" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Save" Disabled="@(string.IsNullOrWhiteSpace(_name))">
            Speichern
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string HomeId { get; set; } = string.Empty;
    [Parameter] public StorageLocation? Location { get; set; }

    private string _name = string.Empty;
    private string _description = string.Empty;

    protected override void OnParametersSet()
    {
        if (Location != null)
        {
            _name = Location.Name;
            _description = Location.Description ?? string.Empty;
        }
    }

    private async Task Save()
    {
        if (Location == null)
        {
            await ShmantryService.CreateStorageLocationAsync(
                HomeId, _name.Trim(),
                string.IsNullOrWhiteSpace(_description) ? null : _description.Trim());
            Snackbar.Add($"'{_name}' angelegt.", Severity.Success);
        }
        else
        {
            Location.Name = _name.Trim();
            Location.Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim();
            await ShmantryService.UpdateStorageLocationAsync(Location);
            Snackbar.Add($"'{_name}' aktualisiert.", Severity.Success);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
