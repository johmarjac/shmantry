@page "/home"
@page "/"
@inject IShmantryService ShmantryService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Dashboard – Shmantry</PageTitle>

<style>
    .tree-home-row {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 16px; cursor: pointer;
        transition: background 0.1s;
    }
    .tree-home-row:hover { background: rgba(255,255,255,0.04); }
    .tree-loc-row {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 16px 9px 44px;
        background: #161618; cursor: pointer;
        transition: background 0.1s;
    }
    .tree-loc-row:hover { background: #1a1a1c; }
</style>

<MudContainer Class="pa-4 pb-20">
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:700;">Dashboard</MudText>

    @if (_loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else
    {
        @* ── Card 1: Article overview ── *@
        <MudPaper Elevation="0" Class="pa-4 mb-3" Style="background:#1c1c1e;border-radius:16px;">
            <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600;">Artikelübersicht</MudText>
            <div class="d-flex align-center gap-4 flex-wrap">
                @if (_totalQty == 0)
                {
                    <div style="width:140px;height:140px;border-radius:50%;background:#2c2c2e;
                                display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Style="color:#3d3d3f;font-size:48px;" />
                    </div>
                }
                else
                {
                    <div style="flex-shrink:0;">
                        <MudChart T="double" ChartType="@ChartType.Donut"
                                  InputData="@_chartData"
                                  InputLabels="@_chartLabels"
                                  Width="140px" Height="140px"
                                  ChartOptions="@_chartOptions" />
                    </div>
                }
                <div class="d-flex flex-column gap-2" style="flex:1;min-width:150px;">
                    <div class="d-flex align-center gap-2 mb-1">
                        <span style="font-size:24px;font-weight:700;color:#f0f0f0;">@_totalQty</span>
                        <span style="font-size:13px;color:#9e9e9e;">Artikel gesamt</span>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width:10px;height:10px;border-radius:50%;background:#4caf50;flex-shrink:0;"></div>
                        <span style="font-size:14px;font-weight:600;color:#f0f0f0;min-width:32px;text-align:right;">@_freshQty</span>
                        <span style="font-size:12px;color:#9e9e9e;">Haltbar</span>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width:10px;height:10px;border-radius:50%;background:#ff9800;flex-shrink:0;"></div>
                        <span style="font-size:14px;font-weight:600;color:#f0f0f0;min-width:32px;text-align:right;">@_soonQty</span>
                        <span style="font-size:12px;color:#9e9e9e;">Läuft bald ab</span>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width:10px;height:10px;border-radius:50%;background:#f44336;flex-shrink:0;"></div>
                        <span style="font-size:14px;font-weight:600;color:#f0f0f0;min-width:32px;text-align:right;">@_expiredQty</span>
                        <span style="font-size:12px;color:#9e9e9e;">Abgelaufen</span>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width:10px;height:10px;border-radius:50%;background:#6e6e73;flex-shrink:0;"></div>
                        <span style="font-size:14px;font-weight:600;color:#f0f0f0;min-width:32px;text-align:right;">@_noDateQty</span>
                        <span style="font-size:12px;color:#9e9e9e;">Kein MHD</span>
                    </div>
                </div>
            </div>
        </MudPaper>

        @* ── Card 2: Household tree ── *@
        <MudPaper Elevation="0" Style="background:#1c1c1e;border-radius:16px;overflow:hidden;">
            <div class="pa-4 pb-2 d-flex align-center">
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;flex:1;">Haushalte & Lagerorte</MudText>
            </div>

            @if (_homeData.Count == 0)
            {
                <div class="pa-4 pt-0 d-flex flex-column align-center">
                    <MudText Color="Color.Secondary" Typo="Typo.body2">
                        Noch keine Haushalte. Tippe auf + um einen hinzuzufügen.
                    </MudText>
                </div>
            }
            else
            {
                @foreach (var hd in _homeData)
                {
                    var isOpen = _expandedHomes.Contains(hd.Home.Id);
                    @* Home row *@
                    <div style="border-top:1px solid #2c2c2e;">
                        <div class="tree-home-row" @onclick="() => ToggleHome(hd.Home.Id)">
                            <MudIcon Icon="@(isOpen ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder)"
                                     Style="color:#fd8122;flex-shrink:0;" Size="Size.Small" />
                            <span style="font-size:15px;font-weight:600;color:#f0f0f0;flex:1;">@hd.Home.Name</span>
                            <span @onclick:stopPropagation="true" class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => AddLocation(hd.Home)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               OnClick="() => EditHome(hd.Home)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="() => DeleteHome(hd.Home)" />
                            </span>
                        </div>

                        @if (isOpen)
                        {
                            @if (hd.Locations.Count == 0)
                            {
                                <div style="border-top:1px solid #2c2c2e;background:#161618;
                                            padding:10px 16px 10px 44px;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Keine Lagerorte – tippe auf + um einen hinzuzufügen.
                                    </MudText>
                                </div>
                            }
                            @foreach (var loc in hd.Locations)
                            {
                                var stats = GetLocationStats(loc.Id);
                                <div class="tree-loc-row" style="border-top:1px solid #2c2c2e;"
                                     @onclick="() => GoToInventoryFiltered(hd.Home.Id, loc.Id)">
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2"
                                             Size="Size.Small" Style="color:#6e6e73;flex-shrink:0;" />
                                    <span style="font-size:14px;color:#e0e0e0;flex:1;overflow:hidden;
                                                 text-overflow:ellipsis;white-space:nowrap;">
                                        @loc.Name
                                    </span>
                                    @if (stats.Total > 0)
                                    {
                                        <span style="background:#2c2c2e;color:#9e9e9e;border-radius:10px;
                                                     padding:1px 8px;font-size:12px;font-weight:600;
                                                     white-space:nowrap;flex-shrink:0;">
                                            @stats.Total
                                        </span>
                                    }
                                    @if (stats.Fresh > 0)
                                    {
                                        <span style="background:#1b3a1f;color:#4caf50;border-radius:10px;
                                                     padding:1px 8px;font-size:12px;font-weight:600;
                                                     white-space:nowrap;flex-shrink:0;">
                                            @stats.Fresh
                                        </span>
                                    }
                                    @if (stats.Soon > 0)
                                    {
                                        <span style="background:#3a2a0a;color:#ff9800;border-radius:10px;
                                                     padding:1px 8px;font-size:12px;font-weight:600;
                                                     white-space:nowrap;flex-shrink:0;">
                                            @stats.Soon
                                        </span>
                                    }
                                    @if (stats.Expired > 0)
                                    {
                                        <span style="background:#3a0f0f;color:#f44336;border-radius:10px;
                                                     padding:1px 8px;font-size:12px;font-weight:600;
                                                     white-space:nowrap;flex-shrink:0;">
                                            @stats.Expired
                                        </span>
                                    }
                                    <span @onclick:stopPropagation="true" class="d-flex align-center">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       OnClick="() => EditLocation(hd.Home, loc)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="() => DeleteLocation(loc)" />
                                    </span>
                                </div>
                            }
                        }
                    </div>
                }
            }
        </MudPaper>
    }
</MudContainer>

<MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        Style="position:fixed;bottom:72px;right:16px;z-index:100;"
        OnClick="AddHome" />

@code {
    private sealed record HomeData(Models.Home Home, List<StorageLocation> Locations);
    private sealed record LocationStats(int Total, int Fresh, int Soon, int Expired);

    private bool _loading = true;
    private List<HomeData> _homeData = [];
    private List<ItemEntryWithDetails> _allEntries = [];
    private readonly HashSet<string> _expandedHomes = [];

    private int _totalQty, _freshQty, _soonQty, _expiredQty, _noDateQty;
    private double[] _chartData = [];
    private string[] _chartLabels = [];
    private readonly ChartOptions _chartOptions = new()
    {
        ChartPalette = ["#4caf50", "#ff9800", "#f44336", "#6e6e73"],
        ShowLegend = false
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var homes = await ShmantryService.GetHomesAsync();
        _allEntries = await ShmantryService.GetAllItemEntriesAsync();

        _homeData.Clear();
        foreach (var h in homes)
        {
            var locs = await ShmantryService.GetStorageLocationsAsync(h.Id);
            _homeData.Add(new HomeData(h, locs));
            _expandedHomes.Add(h.Id);
        }

        _totalQty   = _allEntries.Sum(e => e.Quantity);
        _expiredQty = _allEntries.Where(e => e.IsExpired).Sum(e => e.Quantity);
        _soonQty    = _allEntries.Where(e => e.IsExpiringSoon && !e.IsExpired).Sum(e => e.Quantity);
        _freshQty   = _allEntries.Where(e => e.BestBeforeDate.HasValue && !e.IsExpiringSoon).Sum(e => e.Quantity);
        _noDateQty  = _allEntries.Where(e => !e.BestBeforeDate.HasValue).Sum(e => e.Quantity);

        _chartData   = [(double)_freshQty, (double)_soonQty, (double)_expiredQty, (double)_noDateQty];
        _chartLabels = ["Haltbar", "Läuft bald ab", "Abgelaufen", "Kein MHD"];

        _loading = false;
    }

    private LocationStats GetLocationStats(string locationId)
    {
        var entries = _allEntries.Where(e => e.StorageLocationId == locationId).ToList();
        return new LocationStats(
            Total:   entries.Sum(e => e.Quantity),
            Fresh:   entries.Where(e => e.BestBeforeDate.HasValue && !e.IsExpiringSoon).Sum(e => e.Quantity),
            Soon:    entries.Where(e => e.IsExpiringSoon && !e.IsExpired).Sum(e => e.Quantity),
            Expired: entries.Where(e => e.IsExpired).Sum(e => e.Quantity));
    }

    private void GoToInventoryFiltered(string homeId, string locationId) =>
        Navigation.NavigateTo($"inventory?homeId={Uri.EscapeDataString(homeId)}&locationId={Uri.EscapeDataString(locationId)}");

    private void ToggleHome(string homeId)
    {
        if (!_expandedHomes.Add(homeId))
            _expandedHomes.Remove(homeId);
    }

    private async Task AddHome()
    {
        var d = await DialogService.ShowAsync<HomeDialog>("Haushalt hinzufügen");
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task EditHome(Models.Home home)
    {
        var p = new DialogParameters<HomeDialog> { { x => x.Home, home } };
        var d = await DialogService.ShowAsync<HomeDialog>("Haushalt bearbeiten", p);
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task DeleteHome(Models.Home home)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            "Haushalt löschen",
            $"'{home.Name}' und alle darin enthaltenen Lagerorte und Vorräte wirklich löschen?",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (ok == true)
        {
            await ShmantryService.DeleteHomeAsync(home.Id);
            Snackbar.Add($"'{home.Name}' gelöscht.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task AddLocation(Models.Home home)
    {
        var p = new DialogParameters<StorageLocationDialog> { { x => x.HomeId, home.Id } };
        var d = await DialogService.ShowAsync<StorageLocationDialog>("Lagerort hinzufügen", p);
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task EditLocation(Models.Home home, StorageLocation loc)
    {
        var p = new DialogParameters<StorageLocationDialog>
        {
            { x => x.HomeId, home.Id },
            { x => x.Location, loc }
        };
        var d = await DialogService.ShowAsync<StorageLocationDialog>("Lagerort bearbeiten", p);
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task DeleteLocation(StorageLocation loc)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            "Lagerort löschen",
            $"'{loc.Name}' und alle darin enthaltenen Vorräte wirklich löschen?",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (ok == true)
        {
            await ShmantryService.DeleteStorageLocationAsync(loc.Id);
            Snackbar.Add($"'{loc.Name}' gelöscht.", Severity.Success);
            await LoadAsync();
        }
    }
}
