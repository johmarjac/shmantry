@page "/settings"
@inject IShmantryService ShmantryService
@inject NavigationManager Navigation
@inject IFormFactor FormFactor
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Einstellungen – Shmantry</PageTitle>

<MudContainer Class="pa-4 pb-20">
    <MudText Typo="Typo.h5" Class="mb-5" Style="font-weight:700;">Einstellungen</MudText>

    @* ── General preferences ───────────────────────────────────────────────── *@
    <MudPaper Class="pa-4 mb-3" Elevation="0" Style="background:#1c1c1e;border-radius:16px;">
        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Allgemein</MudText>
        </div>
        <MudText Typo="Typo.body2" Class="mb-3" Style="color:#9e9e9e;">
            Artikel werden als „läuft bald ab" markiert, wenn ihr MHD innerhalb der
            angegebenen Anzahl von Tagen liegt.
        </MudText>
        <div class="d-flex align-end gap-3">
            <MudNumericField @bind-Value="_expiryDays" Label="Ablaufwarnung (Tage)"
                             Variant="Variant.Outlined" Min="1" Max="365"
                             Style="max-width:200px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveSettings" Disabled="@_busy">
                Speichern
            </MudButton>
        </div>
    </MudPaper>

    @if (FormFactor.GetFormFactor() == "Web")
    {
        @* ── OneDrive ──────────────────────────────────────────────────────── *@
        <MudPaper Class="pa-4 mb-3" Elevation="0" Style="background:#1c1c1e;border-radius:16px;">
            <div class="d-flex align-center gap-2 mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1">OneDrive-Synchronisation</MudText>
            </div>

            @if (!_jsReady)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else if (!_odSignedIn)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Melde dich mit deinem Microsoft-Konto an, um Daten automatisch in
                    deinem OneDrive zu sichern und geräteübergreifend zu synchronisieren.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Login"
                           OnClick="SignIn" Disabled="@_busy">
                    Mit Microsoft anmelden
                </MudButton>
            }
            else
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                         Size="Size.Small" Class="mb-3">
                    @_accountName
                </MudChip>
                <div class="d-flex gap-2 flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="SaveToOneDrive" Disabled="@_busy">
                        In OneDrive speichern
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudDownload"
                               OnClick="LoadFromOneDrive" Disabled="@_busy">
                        Von OneDrive laden
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary"
                               OnClick="SignOut" Disabled="@_busy">
                        Abmelden
                    </MudButton>
                </div>
            }
        </MudPaper>

        @* ── Local backup ──────────────────────────────────────────────────── *@
        <MudPaper Class="pa-4 mb-3" Elevation="0" Style="background:#1c1c1e;border-radius:16px;">
            <div class="d-flex align-center gap-2 mb-2">
                <MudIcon Icon="@Icons.Material.Filled.FolderZip" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Lokale Sicherung</MudText>
            </div>
            <MudText Typo="Typo.body2" Class="mb-3" Style="color:#9e9e9e;">
                Exportiere alle Daten als JSON-Datei auf dein Gerät.
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportLocal" Disabled="@_busy">
                Exportieren
            </MudButton>
        </MudPaper>

        @* ── Reset ─────────────────────────────────────────────────────────── *@
        <MudPaper Class="pa-4" Elevation="0" Style="background:#1c1c1e;border-radius:16px;">
            <div class="d-flex align-center gap-2 mb-2">
                <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" />
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Zurücksetzen</MudText>
            </div>
            <MudText Typo="Typo.body2" Class="mb-3" Style="color:#9e9e9e;">
                Alle lokalen Daten löschen und zur Startseite zurückkehren.
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.DeleteForever"
                       OnClick="ResetData" Disabled="@_busy">
                Zurücksetzen
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="0" Style="background:#1c1c1e;border-radius:16px;">
            <MudText Typo="Typo.body1" Class="mb-2" Style="font-weight:600;">Datenbankdatei</MudText>
            <MudText Typo="Typo.body2" Style="color:#9e9e9e;">
                Die SQLite-Datenbank wird im App-Verzeichnis gespeichert.
                Für geräteübergreifende Synchronisierung kopiere die Datei in einen
                Sync-Ordner (OneDrive, Dropbox) und öffne sie über „Datenbank öffnen".
            </MudText>
        </MudPaper>
    }

    @if (_busy)
    {
        <div class="d-flex justify-center mt-4">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
</MudContainer>

@code {
    private bool _jsReady;
    private bool _busy;
    private bool _odSignedIn;
    private string? _accountName;
    private int _expiryDays = 7;

    protected override async Task OnInitializedAsync()
    {
        var settings = await ShmantryService.GetSettingsAsync();
        _expiryDays = settings.ExpiryWarningDays;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _odSignedIn = await JS.InvokeAsync<bool>("shmantry.oneDrive.isSignedIn");
        if (_odSignedIn)
            _accountName = await JS.InvokeAsync<string?>("shmantry.oneDrive.getAccountName");
        _jsReady = true;
        StateHasChanged();
    }

    private async Task SaveSettings()
    {
        _busy = true;
        await ShmantryService.SaveSettingsAsync(new AppSettings { ExpiryWarningDays = _expiryDays });
        Snackbar.Add("Einstellungen gespeichert.", Severity.Success);
        _busy = false;
    }

    private async Task SignIn()
    {
        _busy = true;
        try
        {
            await JS.InvokeVoidAsync("shmantry.oneDrive.signIn");
            _odSignedIn = true;
            _accountName = await JS.InvokeAsync<string?>("shmantry.oneDrive.getAccountName");
            Snackbar.Add("Erfolgreich angemeldet.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Anmeldefehler: {ex.Message}", Severity.Error);
        }
        _busy = false;
    }

    private async Task SignOut()
    {
        _busy = true;
        try
        {
            await JS.InvokeVoidAsync("shmantry.oneDrive.signOut");
            _odSignedIn = false;
            _accountName = null;
            Snackbar.Add("Abgemeldet.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        _busy = false;
    }

    private async Task SaveToOneDrive()
    {
        _busy = true;
        try
        {
            var json = await ShmantryService.ExportDataAsync();
            await JS.InvokeVoidAsync("shmantry.oneDrive.saveFile", json);
            Snackbar.Add("In OneDrive gespeichert.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        _busy = false;
    }

    private async Task LoadFromOneDrive()
    {
        _busy = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("shmantry.oneDrive.loadFile");
            if (json == null)
            {
                Snackbar.Add("Keine Sicherung in OneDrive gefunden.", Severity.Info);
            }
            else
            {
                var ok = await ShmantryService.ImportDataAsync(json);
                if (ok) { Snackbar.Add("Daten aus OneDrive geladen.", Severity.Success); Navigation.NavigateTo("home"); return; }
                Snackbar.Add("Daten konnten nicht importiert werden.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
        }
        _busy = false;
    }

    private async Task ExportLocal()
    {
        _busy = true;
        try
        {
            var json = await ShmantryService.ExportDataAsync();
            var filename = $"shmantry-backup-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("shmantry.downloadFile", filename, json);
        }
        catch
        {
            Snackbar.Add("Fehler beim Exportieren.", Severity.Error);
        }
        _busy = false;
    }

    private async Task ResetData()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Daten zurücksetzen",
            "Alle lokalen Daten unwiderruflich löschen?",
            yesText: "Zurücksetzen", cancelText: "Abbrechen");

        if (confirmed == true)
        {
            ShmantryService.CloseDatabase();
            Navigation.NavigateTo("setup");
        }
    }
}
