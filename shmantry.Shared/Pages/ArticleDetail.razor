@page "/inventory/article/{FoodItemId}"
@inject IShmantryService ShmantryService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@_name – Shmantry</PageTitle>

<style>
    .art-card   { background: #1c1c1e; border-radius: 14px; overflow: hidden; }
    .art-row    { display: flex; align-items: center; gap: 10px; padding: 12px; }
    .art-edit   { background: #242426; padding: 12px; border-top: 1px solid #2c2c2e; }
    .art-loc    { font-size: 12px; color: #9e9e9e; margin-bottom: 4px; }
</style>

<MudContainer Class="pa-4 pb-20">
    <div class="d-flex align-center gap-2 mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("inventory"))" />
        <MudText Typo="Typo.h5" Style="flex:1;font-weight:700;">@_name</MudText>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else
    {
        @* ── Food item header ── *@
        <MudPaper Elevation="0" Class="pa-4 mb-4 d-flex gap-3 align-center"
                  Style="background:#1c1c1e;border-radius:16px;">
            @if (!string.IsNullOrEmpty(_imageUrl))
            {
                <img src="@_imageUrl"
                     style="width:80px;height:80px;border-radius:12px;object-fit:cover;flex-shrink:0;" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:12px;background:#2c2c2e;
                            display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <MudIcon Icon="@Icons.Material.Filled.SetMeal" Style="color:#6e6e73;font-size:40px;" />
                </div>
            }
            <div style="flex:1;min-width:0;">
                <MudText Typo="Typo.h6" Style="font-weight:700;line-height:1.2;">@_name</MudText>
                @if (!string.IsNullOrEmpty(_brand))
                {
                    <MudText Typo="Typo.body2" Style="color:#9e9e9e;">@_brand</MudText>
                }
                <div class="d-flex gap-2 mt-2 flex-wrap" style="align-items:center;">
                    @if (!string.IsNullOrEmpty(_nutriScore))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Label="true" Style="margin:0;">
                            Nutri-Score @_nutriScore
                        </MudChip>
                    }
                    @if (!string.IsNullOrEmpty(_barcode))
                    {
                        <span style="font-size:11px;color:#6e6e73;">@_barcode</span>
                    }
                </div>
                <div class="mt-2" style="font-size:13px;color:#fd8122;font-weight:700;">
                    Gesamt: @_entries.Sum(e => e.Quantity) ×
                </div>
            </div>
        </MudPaper>

        @* ── Entries ── *@
        @if (_entries.Count == 0)
        {
            <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="0"
                      Style="border:2px dashed var(--mud-palette-lines-default);border-radius:12px;">
                <MudText Color="Color.Secondary">Keine Einträge vorhanden.</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Nutze + um einen Eintrag hinzuzufügen.</MudText>
            </MudPaper>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var entry in _entries.OrderBy(e => e.BestBeforeDate ?? DateTime.MaxValue))
                {
                    <div class="art-card">
                        @if (_editingId != entry.Id)
                        {
                            @* ── Normal row ── *@
                            <div class="art-row">
                                <div style="flex:1;min-width:0;">
                                    <div class="art-loc">@entry.HomeName – @entry.StorageLocationName</div>
                                    <div class="d-flex align-center gap-2 flex-wrap">
                                        <span style="font-size:16px;font-weight:700;color:#f0f0f0;">
                                            @entry.Quantity ×
                                        </span>
                                        @if (entry.BestBeforeDate.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Label="true" Style="margin:0;"
                                                     Color="@(entry.IsExpired ? Color.Error : entry.IsExpiringSoon ? Color.Warning : Color.Default)">
                                                MHD @entry.BestBeforeDate.Value.ToString("dd.MM.yyyy")
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <span style="font-size:12px;color:#6e6e73;">Kein MHD</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(entry.Notes))
                                    {
                                        <div style="font-size:12px;color:#9e9e9e;margin-top:3px;">@entry.Notes</div>
                                    }
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               OnClick="() => StartEdit(entry)" />
                                <MudIconButton Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small"
                                               OnClick="() => TransferEntry(entry)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="() => DeleteEntry(entry)" />
                            </div>
                        }
                        else
                        {
                            @* ── Inline edit form ── *@
                            <div class="art-row" style="padding-bottom:4px;">
                                <div class="art-loc" style="margin:0;">
                                    @entry.HomeName – @entry.StorageLocationName
                                </div>
                            </div>
                            <div class="art-edit">
                                <div class="d-flex gap-3 align-end flex-wrap">
                                    <MudNumericField @bind-Value="_editQty" Label="Anzahl"
                                                     Variant="Variant.Outlined" Min="1"
                                                     Style="max-width:110px;" Dense="true" />
                                    <MudDatePicker @bind-Date="_editBestBefore"
                                                   Label="MHD (optional)"
                                                   Variant="Variant.Outlined" Clearable="true"
                                                   DateFormat="dd.MM.yyyy" Style="max-width:190px;" />
                                    <div class="d-flex gap-1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                       Color="Color.Primary" Size="Size.Medium"
                                                       OnClick="() => SaveEdit(entry)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Medium" OnClick="CancelEdit" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</MudContainer>

<MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        Style="position:fixed;bottom:72px;right:16px;z-index:100;"
        OnClick="AddEntry" />

@code {
    [Parameter] public string FoodItemId { get; set; } = string.Empty;

    private bool _loading = true;
    private List<ItemEntryWithDetails> _entries = [];
    private string _name      = string.Empty;
    private string? _brand;
    private string? _imageUrl;
    private string? _nutriScore;
    private string? _barcode;

    private string? _editingId;
    private int     _editQty;
    private DateTime? _editBestBefore;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var all = await ShmantryService.GetAllItemEntriesAsync();
        _entries = all.Where(e => e.FoodItemId == FoodItemId).ToList();
        if (_entries.Count > 0)
        {
            var f    = _entries.First();
            _name      = f.Name;
            _brand     = f.Brand;
            _imageUrl  = f.ImageUrl;
            _nutriScore = f.NutriScore;
            _barcode   = f.Barcode;
        }
        _loading = false;
    }

    private void StartEdit(ItemEntryWithDetails entry)
    {
        _editingId      = entry.Id;
        _editQty        = entry.Quantity;
        _editBestBefore = entry.BestBeforeDate;
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEdit(ItemEntryWithDetails entry)
    {
        await ShmantryService.UpdateItemEntryAsync(new ItemEntry
        {
            Id                = entry.Id,
            FoodItemId        = entry.FoodItemId,
            StorageLocationId = entry.StorageLocationId,
            Quantity          = _editQty,
            BestBeforeDate    = _editBestBefore,
            Notes             = entry.Notes
        });
        _editingId = null;
        await LoadAsync();
    }

    private async Task DeleteEntry(ItemEntryWithDetails entry)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            "Eintrag löschen",
            $"{entry.Quantity}× aus '{entry.StorageLocationName}' entfernen?",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (ok == true)
        {
            await ShmantryService.DeleteItemEntryAsync(entry.Id);
            Snackbar.Add("Eintrag gelöscht.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task TransferEntry(ItemEntryWithDetails entry)
    {
        var p = new DialogParameters<TransferDialog> { { x => x.Entry, entry } };
        var d = await DialogService.ShowAsync<TransferDialog>("Artikel umlagern", p);
        if (!(await d.Result).Canceled) await LoadAsync();
    }

    private async Task AddEntry()
    {
        var p = new DialogParameters<QuickAddDialog>
        {
            { x => x.FoodItemId,   FoodItemId },
            { x => x.FoodItemName, _name }
        };
        var d = await DialogService.ShowAsync<QuickAddDialog>("Hinzufügen", p);
        if (!(await d.Result).Canceled) await LoadAsync();
    }
}
