@page "/inventory"
@inject IShmantryService ShmantryService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Vorräte – Shmantry</PageTitle>

<style>
    .inv-entry { background: #1c1c1e; border-radius: 14px; overflow: hidden; cursor: pointer; }
    .inv-entry:hover { background: #242426; }
    .inv-row-main { display: flex; align-items: center; gap: 12px; padding: 12px; }
    .inv-thumb {
        width: 56px; height: 56px; border-radius: 10px; object-fit: cover; flex-shrink: 0;
    }
    .inv-thumb-ph {
        width: 56px; height: 56px; border-radius: 10px; background: #2c2c2e;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .inv-title { font-size: 15px; font-weight: 600; color: #f0f0f0; }
    .inv-sub   { font-size: 12px; color: #6e6e73; margin-top: 1px; }
    .inv-loc   { font-size: 12px; color: #9e9e9e; margin-top: 1px; }
    .inv-expand { border-top: 1px solid #2c2c2e; }
    .inv-actions { display: flex; gap: 4px; padding: 6px 8px 0; }
    .inv-mhd-row {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 12px; border-top: 1px solid #2c2c2e;
    }
    .inv-mhd-qty { font-size: 13px; color: #f0f0f0; min-width: 28px; }
    .inv-mhd-loc { font-size: 11px; color: #6e6e73; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>

<MudContainer Class="pa-4 pb-20">
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:700;">Vorräte</MudText>

    @* ── Filters ── *@
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <MudSelect T="string?" Label="Haushalt" Value="_filterHomeId" ValueChanged="OnHomeFilterChanged"
                   Dense="true" Variant="Variant.Outlined" Clearable="true"
                   Style="min-width:150px;max-width:210px;">
            @foreach (var h in _homes)
            {
                <MudSelectItem Value="@((string?)h.Id)">@h.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string?" Label="Lagerort" Value="_filterLocationId" ValueChanged="OnLocationFilterChanged"
                   Dense="true" Variant="Variant.Outlined" Clearable="true"
                   Disabled="@(_filterHomeId == null)"
                   Style="min-width:150px;max-width:210px;">
            @foreach (var l in _filteredLocations)
            {
                <MudSelectItem Value="@((string?)l.Id)">@l.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="SortMode" Label="Sortierung" @bind-Value="_sortMode"
                   Dense="true" Variant="Variant.Outlined"
                   Style="min-width:150px;max-width:200px;">
            <MudSelectItem Value="SortMode.Name">Name</MudSelectItem>
            <MudSelectItem Value="SortMode.Brand">Marke</MudSelectItem>
            <MudSelectItem Value="SortMode.BestBefore">MHD</MudSelectItem>
            <MudSelectItem Value="SortMode.Quantity">Anzahl</MudSelectItem>
            <MudSelectItem Value="SortMode.CreatedAt">Datum</MudSelectItem>
        </MudSelect>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else
    {
        var groups = BuildGroups().ToList();
        @if (groups.Count == 0)
        {
            <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0"
                      Style="border:2px dashed var(--mud-palette-lines-default);border-radius:12px;">
                <MudIcon Icon="@Icons.Material.Filled.Kitchen" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                <MudText Typo="Typo.h6">Keine Vorräte gefunden</MudText>
                <MudText Color="Color.Secondary" Class="mt-1">Füge Artikel über einen Lagerort hinzu.</MudText>
            </MudPaper>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var group in groups)
                {
                    var isExpanded = _expandedIds.Contains(group.FoodItemId);
                    <div class="inv-entry" @onclick="() => ToggleExpand(group.FoodItemId)">
                        @* ── Collapsed row ── *@
                        <div class="inv-row-main">
                            @if (!string.IsNullOrEmpty(group.ImageUrl))
                            {
                                <img class="inv-thumb" src="@group.ImageUrl" alt="" />
                            }
                            else
                            {
                                <div class="inv-thumb-ph">
                                    <MudIcon Icon="@Icons.Material.Filled.SetMeal" Style="color:#6e6e73;" />
                                </div>
                            }
                            <div style="flex:1;min-width:0;">
                                <div class="inv-title">@group.TotalQuantity × @group.Name</div>
                                @if (!string.IsNullOrEmpty(group.Brand))
                                {
                                    <div class="inv-sub">@group.Brand</div>
                                }
                                @{
                                    var locs = group.Entries
                                        .Select(e => string.IsNullOrEmpty(e.HomeName)
                                            ? e.StorageLocationName
                                            : $"{e.HomeName} – {e.StorageLocationName}")
                                        .Distinct().ToList();
                                }
                                <div class="inv-loc">@string.Join(", ", locs)</div>
                                @* Expiry badges *@
                                <div class="d-flex gap-1 mt-1 flex-wrap" style="align-items:center;">
                                    @if (group.Entries.Any(e => e.IsExpired))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Label="true"
                                                 Style="height:20px;font-size:11px;margin:0;">Abgelaufen</MudChip>
                                    }
                                    else if (group.Entries.Any(e => e.IsExpiringSoon))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Label="true"
                                                 Style="height:20px;font-size:11px;margin:0;">Läuft ab</MudChip>
                                    }
                                    @{
                                        var nearest = group.Entries
                                            .Where(e => e.BestBeforeDate.HasValue)
                                            .OrderBy(e => e.BestBeforeDate)
                                            .FirstOrDefault();
                                    }
                                    @if (nearest != null)
                                    {
                                        <span style="font-size:11px;color:#6e6e73;">MHD: @nearest.BestBeforeDate!.Value.ToString("dd.MM.yy")</span>
                                    }
                                </div>
                            </div>
                            <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                     Style="color:#3d3d3f;flex-shrink:0;" />
                        </div>

                        @* ── Expanded section ── *@
                        @if (isExpanded)
                        {
                            <div class="inv-expand" @onclick:stopPropagation="true">
                                @* Action buttons *@
                                <div class="inv-actions">
                                    <MudTooltip Text="Detailseite">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       OnClick="() => EditEntry(group)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Hinzufügen">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="() => AddEntry(group)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Umlagern">
                                        <MudIconButton Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small"
                                                       OnClick="() => TransferEntry(group.Entries.First())" />
                                    </MudTooltip>
                                    <MudTooltip Text="Löschen">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="() => DeleteGroup(group)" />
                                    </MudTooltip>
                                </div>
                                @* Per-MHD rows *@
                                @foreach (var entry in group.Entries.OrderBy(e => e.BestBeforeDate ?? DateTime.MaxValue))
                                {
                                    <div class="inv-mhd-row">
                                        <span class="inv-mhd-qty">@entry.Quantity ×</span>
                                        @if (entry.BestBeforeDate.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Label="true" Style="height:24px;font-size:12px;margin:0;"
                                                     Color="@(entry.IsExpired ? Color.Error : entry.IsExpiringSoon ? Color.Warning : Color.Default)">
                                                MHD @entry.BestBeforeDate.Value.ToString("dd.MM.yyyy")
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <span style="font-size:12px;color:#6e6e73;">Kein MHD</span>
                                        }
                                        <span class="inv-mhd-loc">@entry.StorageLocationName</span>
                                        <MudIconButton Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small"
                                                       OnClick="() => TransferEntry(entry)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="() => DecrementEntry(entry)" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</MudContainer>

@code {
    private enum SortMode { Name, Brand, BestBefore, Quantity, CreatedAt }

    private sealed class EntryGroup
    {
        public string FoodItemId { get; init; } = string.Empty;
        public string Name { get; init; } = string.Empty;
        public string? Brand { get; init; }
        public string? ImageUrl { get; init; }
        public List<ItemEntryWithDetails> Entries { get; init; } = [];
        public int TotalQuantity => Entries.Sum(e => e.Quantity);
    }

    private bool _loading = true;
    private List<ItemEntryWithDetails> _allEntries = [];
    private List<Models.Home> _homes = [];
    private List<StorageLocation> _filteredLocations = [];
    private string? _filterHomeId;
    private string? _filterLocationId;
    private SortMode _sortMode = SortMode.Name;
    private readonly HashSet<string> _expandedIds = [];

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _homes = await ShmantryService.GetHomesAsync();
        _allEntries = await ShmantryService.GetAllItemEntriesAsync();
        _loading = false;
    }

    private IEnumerable<EntryGroup> BuildGroups()
    {
        var filtered = _allEntries.AsEnumerable();
        if (_filterHomeId != null)     filtered = filtered.Where(e => e.HomeId == _filterHomeId);
        if (_filterLocationId != null) filtered = filtered.Where(e => e.StorageLocationId == _filterLocationId);

        var groups = filtered
            .GroupBy(e => e.FoodItemId)
            .Select(g => new EntryGroup
            {
                FoodItemId = g.Key,
                Name       = g.First().Name,
                Brand      = g.First().Brand,
                ImageUrl   = g.First().ImageUrl,
                Entries    = g.ToList()
            });

        return _sortMode switch
        {
            SortMode.Brand     => groups.OrderBy(g => g.Brand ?? string.Empty).ThenBy(g => g.Name),
            SortMode.BestBefore => groups.OrderBy(g =>
                g.Entries.Where(e => e.BestBeforeDate.HasValue).Min(e => (DateTime?)e.BestBeforeDate) ?? DateTime.MaxValue),
            SortMode.Quantity  => groups.OrderByDescending(g => g.TotalQuantity),
            SortMode.CreatedAt => groups.OrderByDescending(g => g.Entries.Max(e => e.CreatedAt)),
            _                  => groups.OrderBy(g => g.Name)
        };
    }

    private async Task OnHomeFilterChanged(string? homeId)
    {
        _filterHomeId = homeId;
        _filterLocationId = null;
        _filteredLocations = homeId != null
            ? await ShmantryService.GetStorageLocationsAsync(homeId)
            : [];
    }

    private void OnLocationFilterChanged(string? locationId) =>
        _filterLocationId = locationId;

    private void ToggleExpand(string foodItemId)
    {
        if (!_expandedIds.Add(foodItemId))
            _expandedIds.Remove(foodItemId);
    }

    private async Task Reload()
    {
        _allEntries = await ShmantryService.GetAllItemEntriesAsync();
        if (_filterHomeId != null)
            _filteredLocations = await ShmantryService.GetStorageLocationsAsync(_filterHomeId);
    }

    private void EditEntry(EntryGroup group) =>
        Navigation.NavigateTo($"inventory/article/{group.FoodItemId}");

    private async Task AddEntry(EntryGroup group)
    {
        var first = group.Entries.First();
        var p = new DialogParameters<QuickAddDialog>
        {
            { x => x.FoodItemId,        group.FoodItemId },
            { x => x.FoodItemName,      group.Name },
            { x => x.StorageLocationId, first.StorageLocationId }
        };
        var d = await DialogService.ShowAsync<QuickAddDialog>("Hinzufügen", p);
        if (!(await d.Result).Canceled) await Reload();
    }

    private async Task TransferEntry(ItemEntryWithDetails entry)
    {
        var p = new DialogParameters<TransferDialog> { { x => x.Entry, entry } };
        var d = await DialogService.ShowAsync<TransferDialog>("Artikel umlagern", p);
        if (!(await d.Result).Canceled) await Reload();
    }

    private async Task DeleteGroup(EntryGroup group)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Vorrat löschen",
            $"Alle Einträge für '{group.Name}' löschen?",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (confirmed == true)
        {
            foreach (var e in group.Entries)
                await ShmantryService.DeleteItemEntryAsync(e.Id);
            _expandedIds.Remove(group.FoodItemId);
            Snackbar.Add($"'{group.Name}' gelöscht.", Severity.Success);
            await Reload();
        }
    }

    private async Task DecrementEntry(ItemEntryWithDetails entry)
    {
        if (entry.Quantity <= 1)
        {
            await ShmantryService.DeleteItemEntryAsync(entry.Id);
            Snackbar.Add("Eintrag entfernt.", Severity.Success);
        }
        else
        {
            await ShmantryService.UpdateItemEntryAsync(new ItemEntry
            {
                Id = entry.Id, FoodItemId = entry.FoodItemId,
                StorageLocationId = entry.StorageLocationId,
                Quantity = entry.Quantity - 1,
                BestBeforeDate = entry.BestBeforeDate, Notes = entry.Notes
            });
        }
        await Reload();
    }
}
