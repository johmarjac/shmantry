@page "/scan"
@inject IShmantryService ShmantryService
@inject IOpenFoodFactsService OpenFoodFacts
@inject IBarcodeScannerService BarcodeScanner
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Barcode scannen – Shmantry</PageTitle>

<MudContainer Class="pa-4 pb-20">
    <MudText Typo="Typo.h5" Class="mb-4">Barcode scannen</MudText>

    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <div class="d-flex gap-2">
            <MudTextField @bind-Value="_barcode" Label="Barcode" Variant="Variant.Outlined"
                          FullWidth="true" Immediate="true"
                          OnKeyDown="OnBarcodeKeyDown"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.QrCodeScanner"
                          AdornmentColor="Color.Primary"
                          OnAdornmentClick="ScanWithCamera" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SearchBarcode" Disabled="@(string.IsNullOrWhiteSpace(_barcode) || _searching)">
                Suchen
            </MudButton>
        </div>

        @if (!BarcodeScanner.IsSupported)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                Kamera-Scan ist auf dieser Plattform nicht verfügbar. Bitte Barcode manuell eingeben.
            </MudText>
        }
    </MudPaper>

    @if (_searching)
    {
        <div class="d-flex justify-center mt-4">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_searched)
    {
        @if (_lookedUpItem != null)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Produktinfo (OpenFoodFacts)</MudText>
                <div class="d-flex gap-3 align-center mt-1">
                    @if (!string.IsNullOrEmpty(_lookedUpItem.ImageUrl))
                    {
                        <MudImage Src="@_lookedUpItem.ImageUrl" Width="64" Height="64" ObjectFit="ObjectFit.Cover" Class="rounded" />
                    }
                    <div>
                        <MudText Typo="Typo.h6">@_lookedUpItem.Name</MudText>
                        @if (!string.IsNullOrEmpty(_lookedUpItem.Brand))
                        {
                            <MudText Color="Color.Secondary">@_lookedUpItem.Brand</MudText>
                        }
                        @if (!string.IsNullOrEmpty(_lookedUpItem.NutriScore))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Label="true">
                                Nutri-Score @_lookedUpItem.NutriScore
                            </MudChip>
                        }
                    </div>
                </div>
            </MudPaper>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                Kein Produkt in OpenFoodFacts gefunden. Du kannst den Artikel trotzdem manuell hinzufügen.
            </MudAlert>
        }

        @if (_existingEntries.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mb-2">Vorhandene Lagerorte</MudText>
            <MudList T="ItemEntryWithDetails">
                @foreach (var entry in _existingEntries)
                {
                    <MudListItem>
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
                            <div style="flex:1;">
                                <MudText Typo="Typo.body1">@entry.StorageLocationName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@entry.HomeName</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Label="true">@entry.Quantity ×</MudChip>
                            @if (entry.BestBeforeDate.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Label="true"
                                         Color="@(entry.IsExpired ? Color.Error : entry.IsExpiringSoon ? Color.Warning : Color.Default)">
                                    @entry.BestBeforeDate.Value.ToString("dd.MM.yy")
                                </MudChip>
                            }
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
        else if (_searched)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Dieser Artikel ist noch in keinem Lagerort vorhanden.
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.AddShoppingCart"
                   OnClick="AddToStorage" Class="mt-2">
            Zu einem Lagerort hinzufügen
        </MudButton>
    }
</MudContainer>

@code {
    private string _barcode = string.Empty;
    private bool _searching;
    private bool _searched;
    private FoodItem? _lookedUpItem;
    private List<ItemEntryWithDetails> _existingEntries = [];

    private async Task ScanWithCamera()
    {
        if (!BarcodeScanner.IsSupported)
        {
            Snackbar.Add("Kamera-Scan nicht verfügbar.", Severity.Warning);
            return;
        }
        var code = await BarcodeScanner.ScanBarcodeAsync();
        if (!string.IsNullOrEmpty(code))
        {
            _barcode = code;
            await SearchBarcode();
        }
    }

    private async Task OnBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchBarcode();
    }

    private async Task SearchBarcode()
    {
        if (string.IsNullOrWhiteSpace(_barcode)) return;

        _searching = true;
        _searched = false;
        _lookedUpItem = null;
        _existingEntries = [];

        // Check local DB first
        var local = await ShmantryService.GetFoodItemByBarcodeAsync(_barcode.Trim());
        if (local != null)
            _lookedUpItem = local;
        else
        {
            // Lookup OpenFoodFacts
            var off = await OpenFoodFacts.LookupBarcodeAsync(_barcode.Trim());
            if (off != null)
            {
                off = await ShmantryService.SaveFoodItemAsync(off);
                _lookedUpItem = off;
            }
        }

        _existingEntries = await ShmantryService.SearchByBarcodeAsync(_barcode.Trim());

        _searching = false;
        _searched = true;
    }

    private async Task AddToStorage()
    {
        FoodItem foodItem;
        if (_lookedUpItem != null)
        {
            foodItem = _lookedUpItem;
        }
        else
        {
            // Create a minimal food item with just the barcode
            foodItem = new FoodItem { Barcode = _barcode.Trim(), Name = _barcode.Trim() };
            foodItem = await ShmantryService.SaveFoodItemAsync(foodItem);
        }

        var parameters = new DialogParameters
        {
            ["FoodItem"] = foodItem,
            ["StorageLocationId"] = (string?)null
        };
        var dialog = await DialogService.ShowAsync<AddItemDialog>("Zu Lagerort hinzufügen", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            Snackbar.Add("Artikel hinzugefügt.", Severity.Success);
            await SearchBarcode();
        }
    }
}
